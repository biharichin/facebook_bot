[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddf2\ud835\uddfa\ud835\uddfd\ud835\uddf9\ud835\uddee\ud835\uddff\ud835\ude06\"?", "options": ["Very clean or neat", "Worthy of imitation", "Very sharp (sound/look)"], "correct_answer_text": "Worthy of imitation"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddf2\ud835\uddfa\ud835\uddfd\ud835\uddf9\ud835\uddee\ud835\uddff\ud835\ude06\"?", "options": ["Ideal, outstanding", "Visionary, hopeful", "Fickle, impulsive"], "correct_answer_text": "Ideal, outstanding"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddf2\ud835\uddfa\ud835\uddfd\ud835\uddf9\ud835\uddee\ud835\uddff\ud835\ude06\"?", "options": ["Active, energetic", "Impractical, dreamy", "Poor, bad"], "correct_answer_text": "Poor, bad"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddfc\ud835\uddfb\u