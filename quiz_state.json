[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\uddee\ud835\uddff\ud835\uddf1\ud835\ude04\ud835\uddfc\ud835\uddff\ud835\uddf8\ud835\uddf6\ud835\uddfb\ud835\uddf4\"?", "options": ["Ready to fight or argue", "Shows empathy", "Works seriously"], "correct_answer_text": "Works seriously"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\uddee\ud835\uddff\ud835\uddf1\ud835\ude04\ud835\uddfc\ud835\uddff\ud835\uddf8\ud835\uddf6\ud835\uddfb\ud835\uddf4\"?", "options": ["Solid, resilient", "Industrious, diligent", "Shrewd, insightful"], "correct_answer_text": "Industrious, diligent"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\uddee\ud835\uddff\ud835\uddf1\ud835\ude04\ud835\uddfc\ud835\uddff\ud835\uddf8\ud835\uddf6\ud835\uddfb\ud835\uddf4\"?", "options": ["Unsupportive, discouraging", "Interesting, lively", "Lazy, idle"], "correct_answer_text": "Lazy, idle"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \u