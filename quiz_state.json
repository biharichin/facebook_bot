[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddfb\ud835\ude05\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Very worried", "Focused on greatest good for most people", "Thinks logically"], "correct_answer_text": "Very worried"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddfb\ud835\ude05\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Brave, bold", "Patronizing, arrogant", "Nervous, uneasy"], "correct_answer_text": "Nervous, uneasy"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddfb\ud835\ude05\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Relaxed, calm", "Conflict, misalign", "Lenient, relaxed"], "correct_answer_text": "Relaxed, calm"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf1\ud835\uddee\ud835\uddfd\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Adjusts easily", "Self-controlled", "Believable and trustworthy"], "correct_answer_text": "Adjusts easily"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf1\ud835\uddee\ud835\uddfd\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Damaging, harmful", "Mourn, grieve", "Flexible, versatile"], "correct_answer_text": "Flexible, versatile"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf1\ud835\uddee\ud835\uddfd\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Rigid, stubborn", "Objectivity, neutrality", "Random, arbitrary"], "correct_answer_text": "Rigid, stubborn"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf1\ud835\ude03\ud835\uddf2\ud835\uddfb\ud835\ude01\ud835\ude02\ud835\uddff\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Likes risk and excitement", "Completely opposite", "Feels others\u2019 pain"], "correct_answer_text": "Likes risk and excitement"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \