[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddfd\ud835\uddfc\ud835\ude01\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["Strongly influenced positively", "Very bad or evil", "Very clean"], "correct_answer_text": "Very clean"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddfd\ud835\uddfc\ud835\ude01\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["Immaculate, pristine", "Creative, inventive", "Hard, exhausting, strenuous"], "correct_answer_text": "Immaculate, pristine"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddfd\ud835\uddfc\ud835\ude01\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["Hopeful, cheerful", "Similarity, agreement", "Dirty, grimy"], "correct_answer_text": "Dirty, grimy"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\uddf6\ud835\uddf1\ud835\uddf2\ud835\uddfc\ud835\ude02\ud8