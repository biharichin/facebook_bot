[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde9\ud835\uddf6\ud835\uddff\ud835\uddee\ud835\uddf9 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Without fear", "Spreading rapidly online", "Strong desire to succeed"], "correct_answer_text": "Spreading rapidly online"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde9\ud835\uddf6\ud835\uddff\ud835\uddee\ud835\uddf9 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Stern, rigid", "Disaster, fiasco", "Popular, widespread"], "correct_answer_text": "Popular, widespread"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde9\ud835\uddf6\ud835\uddff\ud835\uddee\ud835\uddf9 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Unnoticed, obscure", "Unworkable, unrealistic", "Weak, unconvincing"], "correct_answer_text": "Unnoticed, obscure"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\uddf3\ud835\uddf9\ud835\ude02\ud835\uddf2\ud835\uddfb\ud835\uddf0\ud835\uddf2\ud835\uddff (\ud835\udde1\ud835\uddfc\ud835\ude02\ud835\uddfb)\"?", "options": ["A person who affects others\u2019 buying or opinions", "Unpredictable in mood", "To imitate"], "correct_answer_text": "A person who affects others\u2019 buying or opinions"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\uddf3\ud835\uddf9\ud835\ude02\ud835\uddf2\ud835\uddfb\ud835\uddf0\ud835\uddf2\ud835\uddff (\ud835\udde1\ud835\uddfc\ud835\ude02\ud835\uddfb)\"?", "options": ["Promoter, trendsetter", "Difference, inconsistency", "Uncertain, conflicted"], "correct_answer_text": "Promoter, trendsetter"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\uddf3\ud835\uddf9\ud835\ude02\ud835\uddf2\ud835\uddfb\ud835\uddf0\ud835\uddf2\ud835\uddff (\ud835\udde1\ud835\uddfc\ud835\ude02\ud835\uddfb)\"?", "options": ["Follower, unknown", "Satisfied, pleased", "Miserable, sad"], "correct_answer_text": "Follower, unknown"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd5\ud835\uddf6\ud835\uddfb\ud835\uddf4\ud835\uddf2-\ud835\ude04\ud835\uddee\ud835\ude01\ud835\uddf0\ud835\uddf5 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Very responsible", "Extremely careful", "To watch multiple episodes in one sitting"], "correct_answer_text": "To watch multiple episodes in one sitting"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd5\ud835\uddf6\ud835\uddfb\ud835\uddf4\ud835\uddf2-\ud835\ude04\ud835\uddee\ud835\ude01\ud835\uddf0\ud835\uddf5 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Perfect, faultless", "Stream, marathon", "Fulfilled, content"], "correct_answer_text": "Stream, marathon"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd5\ud835\uddf6\ud835\uddfb\ud835\uddf4\ud835\uddf2-\ud835\ude04\ud835\uddee\ud835\ude01\ud835\uddf0\ud835\uddf5 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Krish", "Strong, powerful", "Extrinsic, superficial"], "correct_answer_text": "Krish"}]