[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddea\ud835\uddee\ud835\uddff\ud835\uddfa-\ud835\uddf5\ud835\uddf2\ud835\uddee\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Having good judgment", "Kind and loving", "Possible and practical"], "correct_answer_text": "Kind and loving"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddea\ud835\uddee\ud835\uddff\ud835\uddfa-\ud835\uddf5\ud835\uddf2\ud835\uddee\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Caring, affectionate", "Direct, sincere", "Bitterness, hostility, resentment"], "correct_answer_text": "Caring, affectionate"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddea\ud835\uddee\ud835\uddff\ud835\uddfa-\ud835\uddf5\ud835\uddf2\ud835\uddee\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Superficial, trivial", "Satisfied, pleased", "Cold-hearted, cruel"], "correct_answer_text": "Cold-hearted, cruel"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\