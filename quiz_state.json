[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf9\ud835\ude01\ud835\uddff\ud835\ude02\ud835\uddf6\ud835\ude00\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Lacking confidence", "Very boring and long", "Selflessly concerned for others"], "correct_answer_text": "Selflessly concerned for others"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf9\ud835\ude01\ud835\uddff\ud835\ude02\ud835\uddf6\ud835\ude00\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Selfless, philanthropic", "Chatty, verbose", "Random, subjective"], "correct_answer_text": "Selfless, philanthropic"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\uddf9\ud835\ude01\ud835\uddff\ud835\ude02\ud835\uddf6\ud835\ude00\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Heartless, cruel", "Anxious, tense", "Selfish, egoistic"], "correct_answer_text": "Selfish, egoistic"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \u