[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Genuine and real", "Open to argument", "Aggressively argumentative"], "correct_answer_text": "Open to argument"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Questionable, disputable", "Torrential rain, deluge", "Copy, mimic"], "correct_answer_text": "Questionable, disputable"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Certain, undeniable", "Logical, reasoned", "Cautious, timid"], "correct_answer_text": "Certain, undeniable"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddfb\"?", "options": ["Very good or amazing", "Lasting a short time", "To perceive clearly"], "correct_answer_text": "To perceive clearly"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddfb\"?", "options": ["Organized, orderly", "Age-old, primitive", "Detect, recognize"], "correct_answer_text": "Detect, recognize"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddfb\"?", "options": ["Anxious, worried", "Ignore, overlook", "Minor, insignificant"], "correct_answer_text": "Ignore, overlook"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddff\ud835\uddf2\ud835\uddfd\ud835\uddee\ud835\uddfb\ud835\uddf0\ud835\ude06\"?", "options": ["Very worried or panicked", "Inconsistency", "Very hot (weather or food)"], "correct_answer_text": "Inconsistency"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddff\ud835\uddf2\ud835\uddfd\ud835\uddee\ud835\uddfb\ud835\uddf0\ud835\ude06\"?", "options": ["Difference, contradiction", "Proud, conceited", "Casual, relaxed"], "correct_answer_text": "Difference, contradiction"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf6\ud835\ude00\ud835\uddf0\ud835\uddff\ud835\uddf2\ud835\uddfd\ud835\uddee\ud835\uddfb\ud835\uddf0\ud835\ude06\"?", "options": ["Clear, obvious", "Brave, bold", "Agreement, similarity"], "correct_answer_text": "Agreement, similarity"}]