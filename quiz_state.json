[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddfd\ud835\uddf5\ud835\uddf2\ud835\uddfa\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\uddf9\"?", "options": ["Combination of two different things", "Short-lived", "Losing hope"], "correct_answer_text": "Short-lived"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddfd\ud835\uddf5\ud835\uddf2\ud835\uddfa\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\uddf9\"?", "options": ["Temporary, brief", "Merciful, lenient", "Subtlety, refinement"], "correct_answer_text": "Temporary, brief"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddfd\ud835\uddf5\ud835\uddf2\ud835\uddfa\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\uddf9\"?", "options": ["Agreement, similarity", "Permanent, lasting", "Interest, enthusiasm"], "correct_answer_text": "Permanent, lasting"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddff\ud835\ude02\ud835\uddf1\ud835\uddf6\ud835\ude01\ud835\uddf2\"?", "options": ["Highly educated", "Very hot or bright", "Cares only about self"], "correct_answer_text": "Highly educated"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddff\ud835\ude02\ud835\uddf1\ud835\uddf6\ud835\ude01\ud835\uddf2\"?", "options": ["Scholarly, learned", "Eloquent, fluent", "Gigantic, huge"], "correct_answer_text": "Scholarly, learned"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddff\ud835\ude02\ud835\uddf1\ud835\uddf6\ud835\ude01\ud835\uddf2\"?", "options": ["Impractical, dreamy", "Ignorant, uneducated", "Relaxed, calm"], "correct_answer_text": "Ignorant, uneducated"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["To surrender", "To worsen", "Model or framework"], "correct_answer_text": "To worsen"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["Aggravate, intensify", "Acquit, absolve", "Neutral, impartial"], "correct_answer_text": "Aggravate, intensify"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\uddf0\ud835\uddf2\ud835\uddff\ud835\uddef\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["Rough, harsh", "Improve, relieve", "Superficial, trivial"], "correct_answer_text": "Improve, relieve"}]