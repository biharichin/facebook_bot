[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde8\ud835\uddfd\ud835\uddf4\ud835\uddff\ud835\uddee\ud835\uddf1\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["To improve or replace with a better version", "Very bad or evil", "To agree"], "correct_answer_text": "To improve or replace with a better version"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde8\ud835\uddfd\ud835\uddf4\ud835\uddff\ud835\uddee\ud835\uddf1\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Diligent, careful", "Update, enhance", "Honored, satisfied"], "correct_answer_text": "Update, enhance"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde8\ud835\uddfd\ud835\uddf4\ud835\uddff\ud835\uddee\ud835\uddf1\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Downgrade, worsen", "Logical, consistent", "Consistency, logic"], "correct_answer_text": "Downgrade, worsen"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\udddc-\ud835\uddfd\ud835\uddfc\ud835\ude04\ud835\uddf2\ud835\uddff\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Examine closely", "Driven or supported by artificial intelligence", "Recovers quickly"], "correct_answer_text": "Driven or supported by artificial intelligence"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\udddc-\ud835\uddfd\ud835\uddfc\ud835\ude04\ud835\uddf2\ud835\uddff\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Smart, intelligent", "Industrious, persistent", "Rule-of-thumb"], "correct_answer_text": "Smart, intelligent"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd4\ud835\udddc-\ud835\uddfd\ud835\uddfc\ud835\ude04\ud835\uddf2\ud835\uddff\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Explanation, clarity", "Disprove, refute", "Manual, traditional"], "correct_answer_text": "Manual, traditional"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde0\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\uddfa\ud835\uddee\ud835\uddf9\ud835\uddf6\ud835\ude00\ud835\ude01 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Very dirty", "Very loved", "Simple and clean in style"], "correct_answer_text": "Simple and clean in style"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde0\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\uddfa\ud835\uddee\ud835\uddf9\ud835\uddf6\ud835\ude00\ud835\ude01 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Basic, plain", "Vital, crucial", "Direct, sincere"], "correct_answer_text": "Basic, plain"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde0\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\uddfa\ud835\uddee\ud835\uddf9\ud835\uddf6\ud835\ude00\ud835\ude01 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Uninterested, indifferent", "Complex, excessive", "Flawed, imperfect"], "correct_answer_text": "Complex, excessive"}]