[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf0\ud835\uddff\ud835\ude02\ud835\ude01\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddf2\"?", "options": ["Very harmful or destructive", "Feeling hopeless", "Examine closely"], "correct_answer_text": "Examine closely"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf0\ud835\uddff\ud835\ude02\ud835\ude01\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddf2\"?", "options": ["Frightening, horrifying", "Annoyed, irritated", "Inspect, analyze"], "correct_answer_text": "Inspect, analyze"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf0\ud835\uddff\ud835\ude02\ud835\ude01\ud835\uddf6\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddf2\"?", "options": ["Unmotivated, lazy", "Overlook, ignore", "Content, satisfied"], "correct_answer_text": "Overlook, ignore"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud83