[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf2\ud835\uddf9\ud835\uddf3\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["To imitate", "Not caring", "Thinks of others first"], "correct_answer_text": "Thinks of others first"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf2\ud835\uddf9\ud835\uddf3\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["Altruistic, noble", "Caring, affectionate", "Subjectivism"], "correct_answer_text": "Altruistic, noble"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\uddf2\ud835\uddf9\ud835\uddf3\ud835\uddf9\ud835\uddf2\ud835\ude00\ud835\ude00\"?", "options": ["Selfish, egoistic", "Imperfect, flawed", "Naive, foolish"], "correct_answer_text": "Selfish, egoistic"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\ude04\ud835\uddee\ud835\uddff\ud835\uddf1\ud835\uddf9\ud835\ude0