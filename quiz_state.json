[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\ude00\ud835\uddfd\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Hidden", "To mock or ridicule", "Extremely annoyed"], "correct_answer_text": "Extremely annoyed"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\ude00\ud835\uddfd\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Irritated, aggravated", "Shallow, trivial", "Sympathetic, kind"], "correct_answer_text": "Irritated, aggravated"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\uddee\ud835\ude00\ud835\uddfd\ud835\uddf2\ud835\uddff\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Theoretical, speculative", "Calm, pleased", "Ashamed, embarrassed"], "correct_answer_text": "Calm, pleased"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\ude00\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Intellectual rather than emotional", "Strict or severe", "Overwhelmingly happy"], "correct_answer_text": "Overwhelmingly happy"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\ude00\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Kind, sympathetic", "Aggravate, intensify", "Elated, euphoric"], "correct_answer_text": "Elated, euphoric"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\ude00\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Cramped, tiny", "Stupid, dull", "Miserable, dejected"], "correct_answer_text": "Miserable, dejected"}]