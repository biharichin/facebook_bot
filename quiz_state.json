[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd9\ud835\uddee\ud835\uddf0\ud835\uddf6\ud835\uddf9\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["To make easier", "Mysterious or unclear", "Curious and eager to know"], "correct_answer_text": "To make easier"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd9\ud835\uddee\ud835\uddf0\ud835\uddf6\ud835\uddf9\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["Plausible, trustworthy", "Help, assist", "Compassionate, thoughtful"], "correct_answer_text": "Help, assist"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd9\ud835\uddee\ud835\uddf0\ud835\uddf6\ud835\uddf9\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\ude01\ud835\uddf2\"?", "options": ["Hinder, obstruct", "Ignorant, unaware", "Disprove, refute"], "correct_answer_text": "Hinder, obstruct"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\u