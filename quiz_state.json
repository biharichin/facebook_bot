[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\ude01\ud835\uddff\ud835\uddfc\ud835\ude03\ud835\uddf2\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Feeling shy or ashamed", "Social and outgoing", "Very difficult or tiring"], "correct_answer_text": "Social and outgoing"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\ude01\ud835\uddff\ud835\uddfc\ud835\ude03\ud835\uddf2\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Realism, practicality", "Friendly, talkative", "Scholarly, learned"], "correct_answer_text": "Friendly, talkative"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\ude05\ud835\ude01\ud835\uddff\ud835\uddfc\ud835\ude03\ud835\uddf2\ud835\uddff\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["True, valid", "Refute, invalidate", "Introverted, shy"], "correct_answer_text": "Introverted, shy"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb