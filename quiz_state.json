[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddff\ud835\uddff\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Very happy", "State of balance", "Gets angry easily"], "correct_answer_text": "Gets angry easily"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddff\ud835\uddff\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Troubled, uneasy", "Praise, glorify", "Moody, short-tempered"], "correct_answer_text": "Moody, short-tempered"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddff\ud835\uddff\ud835\uddf6\ud835\ude01\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Calm, patient", "Content, satisfied", "Clear, certain"], "correct_answer_text": "Calm, patient"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde3\ud835\uddee\ud835\ude01\ud835\uddf6\ud835\uddf2\ud