[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\uddf9\ud835\uddf2\ud835\uddf0\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Overused", "Positive thinker", "Choosing from many sources"], "correct_answer_text": "Choosing from many sources"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\uddf9\ud835\uddf2\ud835\uddf0\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Diverse, varied", "Antique, archaic", "Determined, resolute"], "correct_answer_text": "Diverse, varied"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf0\ud835\uddf9\ud835\uddf2\ud835\uddf0\ud835\ude01\ud835\uddf6\ud835\uddf0\"?", "options": ["Uniform, limited", "Weak, unconvincing", "Uninspiring, dull"], "correct_answer_text": "Uniform, limited"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf4\ud835\uddff\ud835\uddf2\ud835\uddf4\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Without worry", "Outstandingly bad", "Very hungry"], "correct_answer_text": "Outstandingly bad"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf4\ud835\uddff\ud835\uddf2\ud835\uddf4\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Shocking, terrible", "Huge, evil", "Selfless, charitable"], "correct_answer_text": "Shocking, terrible"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf4\ud835\uddff\ud835\uddf2\ud835\uddf4\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Bored, disinterested", "Excellent, admirable", "Lenient, indulgent"], "correct_answer_text": "Excellent, admirable"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf9\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Stubbornly opinionated", "Very happy", "Deeply sad or thoughtful"], "correct_answer_text": "Very happy"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf9\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Sinister, malevolent", "Articulate, expressive", "Joyful, thrilled"], "correct_answer_text": "Joyful, thrilled"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd8\ud835\uddf9\ud835\uddee\ud835\ude01\ud835\uddf2\ud835\uddf1\"?", "options": ["Kindness, friendliness", "Miserable, sad", "Lenient, flexible"], "correct_answer_text": "Miserable, sad"}]