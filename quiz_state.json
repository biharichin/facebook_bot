[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfa\ud835\uddfd\ud835\uddf2\ud835\uddf0\ud835\uddf0\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Able to continue long-term", "Very worried or panicked", "Perfect, without fault"], "correct_answer_text": "Perfect, without fault"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfa\ud835\uddfd\ud835\uddf2\ud835\uddf0\ud835\uddf0\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Flawless, perfect", "Expressive, articulate", "Silent, muted"], "correct_answer_text": "Flawless, perfect"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfa\ud835\uddfd\ud835\uddf2\ud835\uddf0\ud835\uddf0\ud835\uddee\ud835\uddef\ud835\uddf9\ud835\uddf2\"?", "options": ["Ignorant, uneducated", "Imperfect, faulty", "Idealistic, impractical"], "correct_answer_text": "Imperfect, faulty"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud83