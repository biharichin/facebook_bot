[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\uddf4\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddee\ud835\uddfb\ud835\ude01\"?", "options": ["Speaks directly", "Emotionally developed", "Aware of something"], "correct_answer_text": "Aware of something"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\uddf4\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddee\ud835\uddfb\ud835\ude01\"?", "options": ["Vital, essential", "Conscious, aware", "Copy, mimic"], "correct_answer_text": "Conscious, aware"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\uddf4\ud835\uddfb\ud835\uddf6\ud835\ude07\ud835\uddee\ud835\uddfb\ud835\ude01\"?", "options": ["Ignorant, unaware", "Shallow, unaware", "Clear, certain"], "correct_answer_text": "Ignorant, unaware"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\uddfb\ud835\uddf0\ud835\ude0