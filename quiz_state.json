[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde5\ud835\uddf2\ud835\uddfa\ud835\uddfc\ud835\ude01\ud835\uddf2 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Very threatening", "Very careful about details", "Working or operating from a distance"], "correct_answer_text": "Working or operating from a distance"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde5\ud835\uddf2\ud835\uddfa\ud835\uddfc\ud835\ude01\ud835\uddf2 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Online, web-based", "Hopeless, frantic", "Online, virtual"], "correct_answer_text": "Online, virtual"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde5\ud835\uddf2\ud835\uddfa\ud835\uddfc\ud835\ude01\ud835\uddf2 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Ignore, differ", "On-site, physical", "Dishonest, deceitful"], "correct_answer_text": "On-site, physical"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \