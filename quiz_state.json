[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\ude00\ud835\uddf6\ud835\uddf1\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Gets angry easily", "Gradually harmful", "Works seriously"], "correct_answer_text": "Gradually harmful"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\ude00\ud835\uddf6\ud835\uddf1\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Stern, rigid", "Praise, glorify", "Subtle, dangerous"], "correct_answer_text": "Subtle, dangerous"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\ude00\ud835\uddf6\ud835\uddf1\ud835\uddf6\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Obvious, harmless", "Careless, sloppy", "Admiration, respect"], "correct_answer_text": "Obvious, harmless"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddc\ud835\uddfb\ud835\ude01\ud835\uddff\ud835\udd