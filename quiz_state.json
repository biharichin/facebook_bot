[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddee\ud835\uddf3\ud835\uddf2\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4(\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Very boring", "Very loud", "Social and outgoing"], "correct_answer_text": "Very loud"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddee\ud835\uddf3\ud835\uddf2\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4(\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Reflective, pensive", "Thorough, extensive", "Thunderous, earsplitting"], "correct_answer_text": "Thunderous, earsplitting"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd7\ud835\uddf2\ud835\uddee\ud835\uddf3\ud835\uddf2\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4(\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Impractical, dreamy", "Silent, quiet", "Blunt, rude"], "correct_answer_text": "Silent, quiet"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\u