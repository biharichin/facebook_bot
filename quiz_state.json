[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddf9\ud835\uddfc\ud835\ude02\ud835\uddf1-\ud835\uddef\ud835\uddee\ud835\ude00\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Unaware of what\u2019s happening", "Stored or managed online instead of locally", "Smart and clever"], "correct_answer_text": "Stored or managed online instead of locally"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddf9\ud835\uddfc\ud835\ude02\ud835\uddf1-\ud835\uddef\ud835\uddee\ud835\ude00\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Copy, mimic", "Obstinate, rigid", "Online, web-based"], "correct_answer_text": "Online, web-based"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddf9\ud835\uddfc\ud835\ude02\ud835\uddf1-\ud835\uddef\ud835\uddee\ud835\ude00\ud835\uddf2\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Offline, local", "Dishonest, secretive", "Corporation, enterprise"], "correct_answer_text": "Offline, local"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\ude01\ud835\uddff\ud835\uddf2\ud835\uddee\ud835\uddfa\ud835\uddf9\ud835\uddf6\ud835\uddfb\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["To make a process more efficient", "Believable and trustworthy", "Shows concern"], "correct_answer_text": "To make a process more efficient"}, {"question_text": "\ud835\udde4\ud835\udff1: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\ude01\ud835\uddff\ud835\uddf2\ud835\uddee\ud835\uddfa\ud835\uddf9\ud835\uddf6\ud835\uddfb\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Simplify, optimize", "Hostile, combative", "Systematic, orderly"], "correct_answer_text": "Simplify, optimize"}, {"question_text": "\ud835\udde4\ud835\udff2: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udde6\ud835\ude01\ud835\uddff\ud835\uddf2\ud835\uddee\ud835\uddfa\ud835\uddf9\ud835\uddf6\ud835\uddfb\ud835\uddf2 (\ud835\udde9\ud835\uddf2\ud835\uddff\ud835\uddef)\"?", "options": ["Clear, obvious", "Relaxed, confident", "Complicate, clutter"], "correct_answer_text": "Complicate, clutter"}, {"question_text": "\ud835\udde4\ud835\udff3: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\ude06\ud835\uddef\ud835\uddff\ud835\uddf6\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Logically consistent", "Very sad", "Combination of two different things"], "correct_answer_text": "Combination of two different things"}, {"question_text": "\ud835\udde4\ud835\udff4: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\ude06\ud835\uddef\ud835\uddff\ud835\uddf6\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Mixed, combined", "Disrespectful, mocking", "Perfect, faultless"], "correct_answer_text": "Mixed, combined"}, {"question_text": "\ud835\udde4\ud835\udff5: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\udddb\ud835\ude06\ud835\uddef\ud835\uddff\ud835\uddf6\ud835\uddf1 (\ud835\uddd4\ud835\uddf1\ud835\uddf7)\"?", "options": ["Explicit, definite", "Beautiful, attractive", "Pure, single"], "correct_answer_text": "Pure, single"}]