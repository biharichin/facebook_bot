[{"question_text": "\ud835\udde4\ud835\udfed: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\ude02\ud835\uddff\ud835\uddee\ud835\uddf4\ud835\uddf2\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Brave and fearless", "Logically consistent", "Very eager or enthusiastic"], "correct_answer_text": "Brave and fearless"}, {"question_text": "\ud835\udde4\ud835\udfee: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\ude00\ud835\ude06\ud835\uddfb\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\ude02\ud835\uddff\ud835\uddee\ud835\uddf4\ud835\uddf2\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Bold, brave", "Merciful, lenient", "See-through, lucid"], "correct_answer_text": "Bold, brave"}, {"question_text": "\ud835\udde4\ud835\udfef: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddee\ud835\uddfb\ud835\ude01\ud835\uddfc\ud835\uddfb\ud835\ude06\ud835\uddfa\ud835\ude00 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\uddfc\ud835\ude02\ud835\uddff\ud835\uddee\ud835\uddf4\ud835\uddf2\ud835\uddfc\ud835\ude02\ud835\ude00\"?", "options": ["Cowardly, timid", "Dull, faded", "Apathetic, bored"], "correct_answer_text": "Cowardly, timid"}, {"question_text": "\ud835\udde4\ud835\udff0: \ud835\uddea\ud835\uddf5\ud835\uddee\ud835\ude01 \ud835\uddf6\ud835\ude00/\ud835\uddee\ud835\uddff\ud835\uddf2 \ud835\ude01\ud835\uddf5\ud835\uddf2 \ud835\uddfa\ud835\uddf2\ud835\uddee\ud835\uddfb\ud835\uddf6\ud835\uddfb\ud835\uddf4 \ud835\uddfc\ud835\uddf3 \"\ud835\uddd6\ud835\udd